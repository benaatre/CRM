// نظام «مشاريع السلطان» CRM — المخطط الأولي (المرحلة ١)
// مرجع البيانات: docs/design-reference/schema.md + بريف التصميم.
// التوليد: npx prisma generate   |   النشر: npx prisma migrate deploy

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // اتصال مجمّع (pooler) لوقت التشغيل
  directUrl = env("DIRECT_URL") // اتصال مباشر للترحيلات (migrate)
}

// ===================== التعدادات (Enums) =====================

/// أدوار المستخدمين — الصلاحيات تُطبّق على الخادم في كل query/action.
enum Role {
  OWNER // المالك — صلاحيات كاملة
  ADMIN // مدير — إدارة الموظفين والتوزيع والتقارير
  EMPLOYEE // موظف مبيعات — يدخل برمز PIN، يشوف عملاءه فقط
}

/// مراحل العميل في خط البيع (كانبان ٩ أعمدة).
enum LeadStage {
  NEW // جديد
  ATTEMPTED // محاولة / لم يرد
  INTERESTED // مهتم
  FOLLOW_UP_LATER // موعد لاحق
  VIEWING // زيارة / معاينة
  NEGOTIATION // تفاوض
  RESERVED // محجوز / عربون
  CLOSED_WON // مقفول - بيع
  CLOSED_LOST // غير مهتم / خاسر
}

enum Priority {
  HIGH // عالية
  MEDIUM // متوسطة
  LOW // منخفضة
}

/// قنوات وصول العميل (مصدر الليد).
enum Channel {
  WHATSAPP // واتساب
  TIKTOK // تيك توك
  META // ميتا (انستقرام/فيسبوك)
  SNAPCHAT // سناب
  GOOGLE // جوجل
  AQAR // عقار
  REFERRAL // إحالة
  VISIT // زيارة
  OTHER // أخرى
}

enum UnitType {
  APARTMENT // شقة
  FLOOR // دور
  GROUND_FLOOR_APARTMENT // شقة دور أرضي
  PENTHOUSE // بنتهاوس
  OTHER // أخرى
}

enum ProjectStatus {
  AVAILABLE // متاح
  UNDER_CONSTRUCTION // تحت الإنشاء
  FINISHING // تشطيبات
  COMPLETED // مكتمل
}

enum UnitStatus {
  AVAILABLE // متاحة
  RESERVED // محجوزة
  SOLD // مباعة
}

/// دور الوحدة (مُهيكل).
enum Floor {
  GROUND // أرضي
  FIRST // أول
  SECOND // ثاني
  TOP // علوي
}

enum PaymentMethod {
  CASH // كاش
  BANK_FINANCE // تمويل بنكي
  CASH_AND_FINANCE // كاش + تمويل بنكي
}

/// طريقة الشراء المفضّلة للعميل.
enum PurchaseMethod {
  CASH // كاش
  BANK_FINANCE // تمويل بنكي (قديم — للتوافق مع بيانات سابقة)
  CASH_AND_FINANCE // كاش + تمويل بنكي
  BANK_FINANCE_SUPPORTED // تمويل بنكي مدعوم
  BANK_FINANCE_UNSUPPORTED // تمويل بنكي غير مدعوم
}

/// هدف الشراء.
enum PurchaseGoal {
  RESIDENCE // سكن
  INVESTMENT // استثمار
  BOTH // الاثنين معًا
}

/// طريقة دفع الكاش داخل الحجز.
enum CashPaymentType {
  CHECK // شيك
  TRANSFER // تحويل
  INSTALLMENTS // دفعات
}

/// أسماء البنوك السعودية (للتمويل).
enum SaudiBank {
  RAJHI // الراجحي
  SNB // الأهلي SNB
  RIYAD // الرياض
  ALBILAD // البلاد
  ALINMA // الإنماء
  SAB // ساب
  SAMBA // سامبا
  ANB // العربي الوطني
  ALJAZIRA // الجزيرة
  OTHER // أخرى
}

enum Nationality {
  SAUDI // سعودي
  RESIDENT // مقيم
}

/// مراحل تقدّم البيع داخل بطاقة الحجز.
enum BookingStage {
  RESERVATION // حجز
  PAPERWORK // أوراق
  VALUATION // تقييم
  SIGNING // توقيع
  TRANSFER // إفراغ
  SOLD // بيع
  DELIVERED // تم الاستلام
}

enum DeliveryStatus {
  PENDING // لم يُسلّم
  SCHEDULED // مجدول
  DELIVERED // تم التسليم
}

/// أنواع النشاطات/التفاعلات (للتحليلات: محاولات، زيارات، مواعيد، سرعة الرد).
enum ActivityType {
  CALL // اتصال / محاولة
  WHATSAPP // رسالة واتساب
  VISIT // زيارة / معاينة
  APPOINTMENT // موعد
  NOTE // ملاحظة
  STAGE_CHANGE // تغيير مرحلة
  ASSIGNMENT // توزيع/نقل
}

/// قسم المتابعة (لعرضه في سجل المتابعات وتجميعها).
enum FollowUpSection {
  INTERESTED // مهتم
  NO_ANSWER // لم يرد
  NOT_INTERESTED // غير مهتم
}

/// نوع متابعة العميل (FollowUp).
enum FollowUpType {
  CALL // اتصال
  WHATSAPP // واتساب
  VISIT_PROJECT // زيارة المشروع
  VISIT_OFFICE // زيارة الشركة
  OTHER // أخرى
}

/// نتيجة المتابعة — تحدّد مرحلة العميل تلقائيًا.
enum FollowUpResult {
  INTERESTED_SCHEDULED // مهتم - جدول موعد
  INTERESTED_SENT_INFO // مهتم - أُرسلت معلومات
  INTERESTED_VISITED // مهتم - زار
  NEGOTIATING // تفاوض
  NOT_ANSWERED_SCHEDULED // لم يرد - جُدولت محاولة
  NOT_ANSWERED_WHATSAPP // لم يرد - أُرسل واتساب
  NOT_INTERESTED_LOCATION // غير مهتم - الموقع
  NOT_INTERESTED_SPACE // غير مهتم - المساحة
  NOT_INTERESTED_PRICE // غير مهتم - السعر
  NOT_INTERESTED_FINAL // غير مهتم نهائيًا
  FOLLOW_UP_SCHEDULED // موعد لاحق — جُدولت متابعة (سيستخير / نعاوده لاحقًا)
  BOOKED // تم الحجز
}

// ===================== الجداول (Models) =====================

/// المستخدمون (مالك/مدير/موظف). الموظف يسجّل الدخول برمز PIN.
model User {
  id           String   @id @default(cuid())
  name         String
  phone        String?  @unique
  email        String?  @unique
  role         Role     @default(EMPLOYEE)
  /// بصمة كلمة المرور (للمالك/المدير عبر الإيميل) — bcrypt
  passwordHash String?
  /// بصمة رمز PIN (للموظف) — bcrypt
  pinHash      String?
  /// هدف الصفقات المقفولة (لشريط التقدّم في لوحة الأداء)
  targetDeals  Int      @default(0)
  /// الحد الأقصى لعدد العملاء المسندين (اختياري)
  maxClients   Int?
  /// ملاحظات خاصة بالموظف (للمدير)
  staffNotes   String?
  active       Boolean  @default(true)
  /// آخر ظهور (heartbeat) — لحالة الاتصال «متصل الآن / آخر ظهور»
  lastSeenAt   DateTime?

  // ===== إيقاف استقبال العملاء (توفّر الموظف) =====
  /// متوقّف مؤقتًا عن استقبال العملاء الجدد (يُستثنى من التوزيع وإعادة التوجيه)
  availabilityPaused Boolean  @default(false)
  /// سبب الإيقاف: VACATION (إجازة) | REVIEW (مراجعة العملاء) | SICK (مرضي) | BUSY (مشغول)
  pauseReason  String?
  /// وقت الرجوع التلقائي — null = يدوي بلا مدة
  pauseUntil   DateTime?
  /// من أوقفه (معرّف المستخدم — نفسه أو المالك/المدير)
  pausedBy     String?
  /// وقت الإيقاف
  pausedAt     DateTime?
  /// رمز دعوة تغيير الـ PIN (يُرسل بالإيميل) — bcrypt-free، عشوائي + انتهاء
  pinResetToken String?  @unique
  pinResetExp   DateTime?
  /// إبطال كل الجلسات قبل هذا الوقت (خروج من كل الأجهزة) — يُقارَن بـ loginAt في الـJWT
  sessionsValidFrom DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // علاقات
  assignedLeads Lead[]     @relation("LeadAssignee")
  createdLeads  Lead[]     @relation("LeadCreator")
  bookings      Booking[]  @relation("BookingSeller")
  activities    Activity[]
  bookingEvents BookingEvent[]
  auditLogs     AuditLog[]
  /// المشاريع المسموح للموظف بيعها
  allowedProjects Project[] @relation("AllowedSellers")
  notifications Notification[]
  followUps     FollowUp[] @relation("FollowUpCreator")
  sentMessages     ChatMessage[] @relation("ChatSender")
  receivedMessages ChatMessage[] @relation("ChatRecipient")

  @@index([role])
}

/// رسائل الشات الداخلي — جماعي (recipientId = null) أو خاص بين موظفين.
model ChatMessage {
  id          String   @id @default(cuid())
  body        String
  senderId    String
  sender      User     @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)
  /// المستلم — null يعني الشات الجماعي (كل الفريق)
  recipientId String?
  recipient   User?    @relation("ChatRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([recipientId, createdAt])
  @@index([senderId, createdAt])
}

/// المشاريع العقارية (مثال: مشروع السلطان 79 / 80).
model Project {
  id           String        @id @default(cuid())
  name         String
  district     String? // الحي
  description  String? // وصف المشروع
  status       ProjectStatus @default(AVAILABLE)
  priceMin     Decimal?      @db.Decimal(14, 2)
  priceMax     Decimal?      @db.Decimal(14, 2)
  /// الحد الأقصى للخصم — نسبة % و/أو مبلغ ريال (للتحذير في الحجز)
  maxDiscountPercent Decimal? @db.Decimal(5, 2)
  maxDiscountAmount  Decimal? @db.Decimal(14, 2)
  deliveryDate DateTime? // موعد التسليم
  /// رقم ترخيص فال (REGA) — يظهر بزاوية الواجهة
  falLicense   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  units Unit[]
  leads Lead[]
  allowedSellers User[] @relation("AllowedSellers")

  @@index([status])
}

/// الوحدات السكنية داخل المشروع.
model Unit {
  id        String     @id @default(cuid())
  projectId String
  number    String // رقم الوحدة
  type      UnitType   @default(APARTMENT)
  floor     String? // الدور (نص قديم — للتوافق)
  /// الدور المُهيكل (أرضي/أول/ثاني/علوي)
  floorLevel Floor?
  area      Decimal?   @db.Decimal(8, 2) // المساحة م²
  /// المساحة الإجمالية م²
  totalArea Decimal?   @db.Decimal(8, 2)
  price     Decimal?   @db.Decimal(14, 2)
  /// نسبة خصم الوحدة % (اختياري) — السعر بعد الخصم يُحسب منها
  discountPercent Decimal? @db.Decimal(5, 2)
  /// السعر بعد الخصم (صريح) — يُعرض فقط لو موجود
  discountedPrice Decimal? @db.Decimal(14, 2)
  status    UnitStatus @default(AVAILABLE)
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  booking Booking?

  @@unique([projectId, number])
  @@index([status])
}

/// المرحلة الأولى — يحدّدها الموظف مرة واحدة فقط ولا تُعدّل لاحقًا.
enum FirstContactStage {
  INTERESTED // مهتم (أخضر)
  NO_ANSWER // لا يرد (أصفر)
  NOT_INTERESTED // غير مهتم (أحمر)
}

/// العملاء / الليدات — قلب النظام.
model Lead {
  id           String      @id @default(cuid())
  name         String
  phone        String
  nationalId   String? // رقم الهوية
  nationality  Nationality?
  channel      Channel     @default(OTHER)
  /// مصدر العميل عند الاستيراد (نص حرّ — يعكس القناة المختارة للدفعة)
  source       String?
  projectId    String?
  unitType     UnitType?
  budget       Decimal?    @db.Decimal(14, 2)
  /// طريقة الشراء المفضّلة (كاش/تمويل/كاش+تمويل)
  purchaseMethod PurchaseMethod?
  /// هدف الشراء (سكن/استثمار/الاثنين)
  purchaseGoal PurchaseGoal?
  /// الحي المفضّل (قديم — حقل واحد). الجديد: preferredAreas (متعدّد)
  preferredDistrict String?
  /// رينج السعر المناسب
  priceMin     Int?
  priceMax     Int?
  /// الأحياء المناسبة (يكتبها يدويًا، متعدّد)
  preferredAreas String[]
  /// المشاريع المناسبة (معرّفات/أسماء من النظام، متعدّد)
  preferredProjects String[]
  /// المرحلة الأولى — تُحدَّد مرة واحدة فقط
  firstContactStage FirstContactStage?
  /// تاريخ أول تواصل (يُعرض في الجدول)
  firstContactDate DateTime?
  /// مؤرشف — للعملاء المحجوزين/المشترين (ينتقلون لتبويب «تم الحجز/الشراء»)
  isArchived   Boolean     @default(false)
  stage        LeadStage   @default(NEW)
  priority     Priority    @default(MEDIUM)
  /// عدد محاولات التواصل
  attempts     Int         @default(0)
  /// وقت أول تواصل — لقياس سرعة الرد (speed-to-lead)
  firstContactAt DateTime?
  lastContact  DateTime?
  nextFollowup DateTime?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // الإسناد
  assignedToId String?
  assignedTo   User?    @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User?    @relation("LeadCreator", fields: [createdById], references: [id], onDelete: SetNull)

  // ===== التوزيع التلقائي =====
  /// وقت آخر إسناد تلقائي — يبدأ منه عدّاد المهلة قبل إعادة التوجيه
  assignedAt   DateTime?
  /// وقت أول «تواصل» يوقف عدّاد إعادة التوجيه (مكالمة/واتساب/تحديد موعد)
  contactedAt  DateTime?
  /// كم مرة أُعيد توجيه هذا العميل تلقائيًا بسبب التقصير
  reassignCount Int        @default(0)
  /// وقت آخر إسناد يدوي (نقل/توزيع من مدير) — يمنح حصانة ٧٢ ساعة من السحب التلقائي
  manualAssignedAt DateTime?

  // المصدر المهيكل (من جدول LeadSource) — يتعايش مع source النصّي القديم.
  sourceId   String?
  leadSource LeadSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  project    Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  bookings   Booking[]
  activities Activity[]
  followUps  FollowUp[]
  referrals  Referral[]
  reassignments Reassignment[]
  sweepCandidate SweepCandidate?

  @@index([stage])
  @@index([assignedToId])
  @@index([nextFollowup])
  @@index([isArchived])
  @@index([assignedAt])
  @@index([sourceId])
}

/// سجل إعادات التوجيه التلقائية (من → إلى، السبب، الوقت) — للوحة المراقبة.
model Reassignment {
  id         String   @id @default(cuid())
  leadId     String
  fromUserId String?
  toUserId   String?
  /// السبب: timeout (انقضت المهلة بلا تواصل) | initial (إسناد أولي)
  reason     String   @default("timeout")
  createdAt  DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
}

/// مرشّح للسحب (rule 5): الـsweep يكتب هنا بدل ما ينفّذ — المالك يوافق («اسحب») أو يترك.
/// صف واحد معلّق لكل ليد (leadId فريد). يُحذف عند القرار (سحب أو ترك).
model SweepCandidate {
  id             String    @id @default(cuid())
  leadId         String    @unique
  /// الموظف الحالي (المصدر) وقت الترشيح
  fromUserId     String?
  reason         String    @default("timeout")
  /// المهلة المطبّقة (دقائق) التي رشّحته
  timeoutMin     Int?
  /// وقت إسناد الليد وقت الترشيح (لعرضه في القائمة)
  leadAssignedAt DateTime?
  createdAt      DateTime  @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

/// متابعة عميل — نوع + نتيجة + موعد قادم (سجل ذكي مرتّب).
model FollowUp {
  id        String         @id @default(cuid())
  leadId    String
  type      FollowUpType
  note      String?
  result    FollowUpResult
  section   FollowUpSection?
  /// المرحلة التي انتقل إليها العميل بهذه المتابعة (للعرض في السجل)
  stageAfter LeadStage?
  nextDate  DateTime?
  createdAt DateTime       @default(now())
  createdBy String

  lead     Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  employee User @relation("FollowUpCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdBy])
}

/// حجز وحدة لعميل — بطاقة خط المبيعات.
model Booking {
  id            String         @id @default(cuid())
  leadId        String
  unitId        String         @unique
  sellerId      String?
  nationality   Nationality?
  nationalId    String?
  phone         String?
  /// رقم اختياري إضافي للمشتري
  secondaryPhone String?
  paymentMethod PaymentMethod  @default(CASH)
  bankName      SaudiBank?
  deposit       Decimal?       @db.Decimal(14, 2) // العربون
  price         Decimal        @db.Decimal(14, 2)
  discount      Decimal        @default(0) @db.Decimal(14, 2)
  finalPrice    Decimal        @db.Decimal(14, 2) // السعر بعد الخصم
  stage         BookingStage   @default(RESERVATION)
  deliveryStatus DeliveryStatus @default(PENDING)
  /// تجاوز الخصم الحد المسموح للمشروع (يظهر تحذير أحمر للمدير)
  discountExceeded Boolean     @default(false)
  /// نسبة الخصم وقت الحجز و الحد المسموح وقتها (لعرض تفاصيل التجاوز)
  discountPercentAtBooking Decimal? @db.Decimal(5, 2)
  maxDiscountPercentAtBooking Decimal? @db.Decimal(5, 2)
  /// مبلغ تجاوز الخصم المقرر (ر.س) — شريط أحمر بالكرت + إشعار للمالك
  discountOverage Decimal? @db.Decimal(14, 2)
  /// فشل تمويل / رفض بنك (يظهر بأحمر)
  financeRejected Boolean      @default(false)
  /// سبب فشل التمويل
  financeRejectedReason String?
  /// المبلغ المحصّل فعليًا (للتحليلات المالية)
  collected     Decimal        @default(0) @db.Decimal(14, 2)
  /// المبلغ المحصّل وقت الحجز (= العربون)
  collectedAmount Decimal      @default(0) @db.Decimal(14, 2)
  /// المبلغ المتبقي = الإجمالي بعد الخصم (مع VAT لو مفعّل) − العربون
  remainingAmount Decimal      @default(0) @db.Decimal(14, 2)

  // ===== حقول الدفع المرنة =====
  /// موعد الشيك المتوقع (كاش)
  expectedCheckDate DateTime?
  /// تاريخ التحويل المتوقع (كاش - تحويل)
  expectedTransferDate DateTime?
  /// نوع دفع الكاش: شيك / تحويل / دفعات
  cashPaymentType   CashPaymentType?
  installmentsCount Int?
  installmentAmount Decimal?       @db.Decimal(14, 2)
  /// تفاصيل الدفعات [{amount, date}] (JSON)
  installments      Json?
  /// مبلغ الكاش في خيار كاش+تمويل
  cashAmount        Decimal?       @db.Decimal(14, 2)
  /// خاضع لضريبة التصرفات العقارية (5%)؟ (قديم — للتوافق)
  subjectToTax      Boolean        @default(false)
  /// قيمة الضريبة المحسوبة (قديم)
  taxAmount         Decimal?       @db.Decimal(14, 2)
  /// يشمل ضريبة القيمة المضافة (15%)؟
  includesVAT       Boolean        @default(false)
  /// قيمة ضريبة القيمة المضافة المحسوبة (15%)
  vatAmount         Decimal?       @db.Decimal(14, 2)
  /// مؤشّر المرحلة الحالية ضمن قائمة المراحل الديناميكية (القسم ٢)
  stageIndex        Int            @default(0)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  lead   Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  unit   Unit  @relation(fields: [unitId], references: [id], onDelete: Cascade)
  seller User? @relation("BookingSeller", fields: [sellerId], references: [id], onDelete: SetNull)
  events BookingEvent[]

  @@index([stage])
  @@index([sellerId])
  @@index([leadId])
}

/// سجل تغييرات مرحلة الحجز (من غيّرها ومتى) — لخط المبيعات المرئي للكل.
model BookingEvent {
  id        String        @id @default(cuid())
  bookingId String
  userId    String?
  fromStage BookingStage?
  toStage   BookingStage
  note      String?
  createdAt DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([bookingId])
}

/// سجل النشاطات/التفاعلات لكل عميل (للتحليلات).
model Activity {
  id        String       @id @default(cuid())
  leadId    String
  userId    String?
  type      ActivityType
  note      String?
  createdAt DateTime     @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([type])
}

/// إشعار لمستخدم (toast + جرس).
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // مفتاح الحدث (eventKey) أو نوع قديم: lead.new | booking.created | ...
  title     String
  body      String?
  /// رابط يفتح العنصر المرتبط (عميل/وحدة) عند الضغط على الإشعار
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

/// سجل التدقيق العام (من غيّر + متى + ماذا).
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // booking.created / booking.cancelled / booking.stage / lead.created / lead.reassigned ...
  entity    String? // booking | lead | unit
  entityId  String?
  summary   String // وصف عربي مقروء
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
}

/// إعدادات الشركة (سجل واحد singleton).
model Settings {
  id          String   @id @default("singleton")
  companyName String   @default("مشاريع السلطان")
  /// لوجو الشركة (Data URL base64 أو رابط) — يظهر بالهيدر والدخول
  logoUrl     String?
  falLicense  String?
  phone       String?
  /// إسناد العملاء الجدد تلقائيًا لموظف (الأقل حملًا) عند إنشائهم من المدير
  autoAssign  Boolean  @default(false)

  // ===== نظام التوزيع التلقائي الذكي =====
  /// المفتاح الرئيسي لتشغيل/إيقاف التوزيع التلقائي وإعادة التوجيه
  autoDistribute   Boolean  @default(false)
  /// نافذة العمل: ساعة البداية (٢٤) — افتراضي ١ ظهرًا
  distStartHour    Int      @default(13)
  /// نافذة العمل: ساعة النهاية (٢٤) — افتراضي ٩ مساءً
  distEndHour      Int      @default(21)
  /// مدة المهلة بالدقائق قبل إعادة التوجيه — افتراضي ٦٠
  distTimeoutMin   Int      @default(60)
  /// حد «التواجد» بالدقائق (آخر ظهور lastSeenAt) — يُتخطّى من تجاوزه
  distPresenceMin  Int      @default(30)
  /// ترتيب الموظفين المشاركين في الدور (معرّفات User بالترتيب) — فقط هؤلاء يدخلون التوزيع
  distOrder        String[]
  /// مؤشّر الدور الثابت (round-robin) — موضع آخر موظف أُسند له
  distPointer      Int      @default(0)
  /// طريقة التوزيع الأولي: ROUND_ROBIN (دوري ثابت) | LEAST_LOADED (الأقل عملاءً)
  distInitialMode  String   @default("ROUND_ROBIN")
  /// طريقة إعادة التوجيه: MOST_ACTIVE (الأكثر نشاطًا اليوم) | ROTATION (التالي في الدور)
  distReassignMode String   @default("MOST_ACTIVE")
  /// الحاجز التاريخي للسحب: الـsweep يتجاهل أي ليد assignedAt < هذا التاريخ. الافتراضي now
  /// عند الترحيل — يعني كل العملاء الحاليين محميّون فورًا، والسحب يشتغل فقط على ما بعده.
  sweepCutoffAt    DateTime @default(now())

  // ===== آخر دورة كرون (لعرضها في لوحة التوزيع) =====
  /// وقت آخر تشغيل لدورة الكرون (توزيع/سحب)
  lastCronAt          DateTime?
  /// كم عميلًا وُزّع (توزيع أولي) في آخر دورة
  lastCronDistributed Int      @default(0)
  /// كم عميلًا سُحب (إعادة توجيه) في آخر دورة
  lastCronReassigned  Int      @default(0)

  /// رابط جوجل شيت للمزامنة التلقائية (CSV عام أو رابط شيت)
  googleSheetUrl String?
  /// آخر مزامنة ناجحة للشيت
  lastSyncAt  DateTime?
  /// إعدادات الإشعارات (JSON): {sound, volume, types:{}, followupBeforeHours, staleHours}
  notifyConfig Json?
  /// مستوى الصوت الرئيسي للإشعارات (٠–١٠٠)
  masterVolume Int      @default(80)
  /// كتم كل أصوات الإشعارات
  globalMute   Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

/// الإحالات (ما بعد البيع — اطلب إحالة من عميل مقفول).
model Referral {
  id           String   @id @default(cuid())
  fromLeadId   String
  name         String
  phone        String?
  converted    Boolean  @default(false)
  createdAt    DateTime @default(now())

  fromLead Lead @relation(fields: [fromLeadId], references: [id], onDelete: Cascade)

  @@index([fromLeadId])
}

/// مصدر العميل (ميتا/سناب/تيك توك…) — مهيكل، يُربط بالعملاء وروابط جوجل شيت.
model LeadSource {
  id         String      @id @default(cuid())
  name       String      @unique
  isDefault  Boolean     @default(false)
  createdAt  DateTime    @default(now())

  sheetLinks SheetLink[]
  leads      Lead[]
}

/// رابط جوجل شيت مربوط بمصدر — مزامنة تدريجية (lastRowSynced) عبر Service Account.
model SheetLink {
  id             String     @id @default(cuid())
  sheetUrl       String
  sheetId        String
  sourceId       String
  source         LeadSource @relation(fields: [sourceId], references: [id])
  /// آخر صفّ بيانات تمت معالجته (بدون احتساب صف العناوين)
  lastRowSynced  Int        @default(0)
  lastSyncAt     DateTime?
  /// حالة آخر مزامنة: success | error
  lastSyncStatus String?
  lastSyncError  String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())

  @@index([sourceId])
  @@index([isActive])
}

/// إعداد إشعار لكل حدث (صوت/توست/نغمة/جمهور) — صف واحد لكل eventKey.
model NotificationSetting {
  id           String   @id @default(cuid())
  /// مفتاح الحدث: new_lead_from_sheet | lead_assigned | lead_reassigned | employee_idle | followup_due | employee_paused | unit_booked_sold
  eventKey     String   @unique
  soundEnabled Boolean  @default(true)
  toastEnabled Boolean  @default(true)
  /// مستوى صوت هذا الحدث (٠–١٠٠) — يُضرب في مستوى الصوت الرئيسي
  volume       Int      @default(100)
  /// معرّف النغمة المختارة (SoundAsset) — null = النغمة الافتراضية
  soundId      String?
  /// الجمهور: OWNER | MANAGERS | ASSIGNED | MANAGERS_AND_ASSIGNED | ALL
  audience     String   @default("MANAGERS")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// نغمة صوتية — جاهزة (مدمجة) أو مرفوعة من المالك.
model SoundAsset {
  id        String   @id @default(cuid())
  name      String
  fileUrl   String
  isBuiltIn Boolean  @default(false)
  createdAt DateTime @default(now())
}
