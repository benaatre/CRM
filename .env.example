# ===== قاعدة البيانات (PostgreSQL) =====
# على Hostinger: أنشئ قاعدة PostgreSQL من hPanel وخذ بياناتها من هناك.
# الصيغة: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# ===== Auth.js (NextAuth v5) =====
# سر تشفير الجلسات — ولّده مرة وحدة بالأمر:  npx auth secret
AUTH_SECRET="ضع_سرًا_عشوائيًا_طويلًا_هنا"
# رابط الموقع في الإنتاج (مطلوب خلف بروكسي Hostinger)
AUTH_URL="https://your-domain.com"
AUTH_TRUST_HOST="true"

# ===== المساعد الذكي (Anthropic) =====
# يُستخدم في route handler على الخادم فقط — لا يُكشف للمتصفح أبدًا.
ANTHROPIC_API_KEY="sk-ant-..."

# ===== إعدادات النشر =====
# المنفذ — Hostinger يحقنه تلقائيًا، محليًا الافتراضي 3000
# PORT=3000
