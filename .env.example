# ===== قاعدة البيانات (PostgreSQL) =====
# على Hostinger: أنشئ قاعدة PostgreSQL من hPanel وخذ بياناتها من هناك.
# الصيغة: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
# DIRECT_URL: اتصال مباشر للترحيلات (prisma migrate). مع مزوّدين فيهم pooler
# (مثل Neon) ضعه = نفس DATABASE_URL لكن بدون لاحقة "-pooler". غير ذلك = نفس DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# ===== Auth.js (NextAuth v5) =====
# سر تشفير الجلسات — ولّده مرة وحدة بالأمر:  npx auth secret
AUTH_SECRET="ضع_سرًا_عشوائيًا_طويلًا_هنا"
# رابط الموقع في الإنتاج (مطلوب خلف بروكسي Hostinger)
AUTH_URL="https://your-domain.com"
AUTH_TRUST_HOST="true"

# ===== المساعد الذكي (Anthropic) =====
# يُستخدم في route handler على الخادم فقط — لا يُكشف للمتصفح أبدًا.
ANTHROPIC_API_KEY="sk-ant-..."
# الموديل (اختياري) — الافتراضي claude-sonnet-4-6
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ===== مزامنة جوجل شيت (cron) =====
# سرّ يحمي /api/sync-sheet — اضبط cron على Hostinger:
# curl "https://your-domain.com/api/sync-sheet?secret=YOUR_SECRET"
SYNC_SECRET="سرّ_عشوائي_للمزامنة"

# ===== التوزيع التلقائي الذكي (cron) =====
# سرّ يحمي /api/auto-distribute — يفحص العملاء المتأخرين ويعيد توجيههم.
# اضبط Cron Job في hPanel كل دقيقتين (يعمل حتى لو ما أحد يتصفّح الموقع):
#   */2 * * * *  curl -s "https://your-domain.com/api/auto-distribute?secret=YOUR_SECRET"
CRON_SECRET="سرّ_عشوائي_للتوزيع"

# ===== حوكمة «لم يتم الرد» — سحب تلقائي (خلف مفتاح) =====
# تنبيه الموظف بعد ٤٨ ساعة بلا رد، وسحب العميل بعد ٧٢ ساعة (عبر /api/notify-scheduled).
# off (الافتراضي) = DRY_RUN: يسجّل من كان سيُنبَّه/يُسحب بلا أي كتابة. on = تفعيل السحب الحقيقي.
NO_RESPONSE_PULL=off
# تاريخ التفعيل (ISO): العدّاد يبدأ من هذه اللحظة كحدّ أدنى للجميع — يمنع السحب الجماعي
# للمتراكم التاريخي عند أول تشغيل. اتركه فارغًا لتعطيل خطّ الأساس. مثال: 2026-07-19
NO_RESPONSE_ACTIVATION_DATE=

# ===== إعدادات النشر =====
# المنفذ — Hostinger يحقنه تلقائيًا، محليًا الافتراضي 3000
# PORT=3000

# ===== البريد (دعوة تغيير PIN — Nodemailer) =====
# إعدادات SMTP لإرسال دعوات الموظفين لتعيين رمز الدخول
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="no-reply@example.com"
SMTP_PASS="كلمة_سر_التطبيق"
# المرسِل (اختياري — الافتراضي SMTP_USER)
SMTP_FROM="مشاريع السلطان <no-reply@example.com>"
